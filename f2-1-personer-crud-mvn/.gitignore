# Maven
.mvn/          # Ignore the directory containing wrappers, local config, etc.
log/           # Ignore log directory if it's created
target/        # Ignore the directory containing compiled code, packages, etc.

# IntelliJ IDEA
.idea/*         # Project specific files
!.idea/misc.xml # Except this one (contains JDK name and Langauge level)
*.iml           # Module files
*.iws           # Workspace files

# Mac
.DS_Store

# Java-specific ignores
*.class        # Compiled Java class files
*.jar          # Packaged Java archives (JARs)
*.war          # Web application archives (WARs)
*.ear          # Enterprise archives (EARs)

# Generated files
/bin/
/out/